# ─── Resend (contact form emails) ─────────────────────────────────────────────
# Get your free API key at https://resend.com — 3,000 emails/month free tier
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address that receives contact form submissions (defaults to your Gmail)
CONTACT_TO_EMAIL=mielle.almedejar@gmail.com

# The "from" address for outgoing emails.
# With a free Resend account, use: onboarding@resend.dev
# Once you verify your own domain (e.g. mielle.dev), use: contact@mielle.dev
RESEND_FROM_DOMAIN=onboarding@resend.dev
