# ── Neon Postgres ─────────────────────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection string
# Make sure to append ?sslmode=require if not already included
DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Admin auth ────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=your-admin-password-here
# Generate: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here

# ── Existing ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-key-here
